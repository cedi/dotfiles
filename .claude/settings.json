{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "opus[1m]",
  "permissions": {
    "defaultMode": "auto",
    "allow": [],
    "deny": [
      "Edit",
      "Read(//**/.aws/**)",
      "Read(//**/.azure/**)",
      "Read(//**/.kube/**)",
      "Read(//**/.config/gcloud/**)",
      "Read(//**/.env*)",
      "Read(//**/local.settings.json)",
      "Read(//**/*.tfstate*)",
      "Read(//**/*.tfplan)",
      "Read(//**/.terraform.d/**)",
      "Read(//**/.terraform.lock.hcl)",
      "Read(//**/.terraform/**)",
      "Read(//**/.terragrunt-cache/**)",
      "Read(//**/.ssh/**)",
      "Read(//**/.bash_history)",
      "Read(//**/.zsh_history)",
      "Read(//**/.python_history)",
      "Read(//**/.npmrc)",
      "Read(//**/.gitconfig)",
      "Read(//**/.git/**)",
      "Read(//**/.dockercfg)",
      "Read(//**/.docker/config.json)",
      "Read(//**/.vscode/**)",
      "Read(//**/.idea/**)",
      "Read(//**/mcp.json)"
    ],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gcx@gcx-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "git-workflows@cedi-agent-plugins": true,
    "documentation@cedi-agent-plugins": true,
    "tpm@cedi-agent-plugins": true,
    "product-design@cedi-agent-plugins": true,
    "mental-models@cedi-agent-plugins": true
  },
  "extraKnownMarketplaces": {
    "cedi-agent-plugins": {
      "source": {
        "source": "github",
        "repo": "cedi/agent-plugins"
      },
      "autoUpdate": true
    },
    "gcx-marketplace": {
      "source": {
        "source": "github",
        "repo": "grafana/gcx"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "useAutoModeDuringPlan": true
}
